<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Width="400" Height="120" CanResize="False"
        x:Class="Snippy.Views.ImportURLWindow"
        Title="Import Snippet">
        <Border Background="{DynamicResource BackgroundColor}">
                <Grid RowDefinitions="*,Auto" Margin="15">
                        <TextBox Name="UrlTextBox" Grid.Row="0" Watermark="Metadata URL (*.json)"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="8">
                                <Button Content="Cancel" Click="Cancel_OnClick" Background="{DynamicResource CancelButtonColor}" 
                                        Foreground="{DynamicResource CancelButtonTextColor}"
                                        BorderBrush="{DynamicResource CancelButtonBorderColor}"/>
                                <Button Content="Import" Click="Import_OnClick" Background="{DynamicResource ImportButtonColor}" 
                                        Foreground="{DynamicResource ImportButtonTextColor}"
                                        BorderBrush="{DynamicResource ImportButtonBorderColor}"/>
                        </StackPanel>
                </Grid>
        </Border>
</Window>
