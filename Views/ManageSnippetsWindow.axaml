<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Width="400" Height="300" CanResize="False" Icon="/Assets/Images/Desktop-icon.ico"
        x:Class="Snippy.Views.ManageSnippetsWindow"
        Title="Manage Snippets">
        <Border Background="{DynamicResource BackgroundColor}">
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Menu Grid.Row="0" Background="{DynamicResource MenuColor}">
                                <MenuItem Header="Add Snippet">
                                        <MenuItem Header="With Editor" Click="OpenEditor_OnClick"/>
                                        <MenuItem Header="Load from URL" Click="LoadFromURL_OnClick"/>
                                </MenuItem>
                        </Menu>
                        
                        <StackPanel Grid.Row="1" x:Name="SnippetsList" Spacing="15" Margin="10">
                                                                
                        </StackPanel>
                        
                </Grid>
        </Border>
</Window>
